# Copy to .env and fill in values for local development.
# compose.yml reads this automatically via ${VAR:-default} interpolation.

# Postgres credentials (local dev)
DB_USER=mentyx
DB_PASSWORD=mentyx
DB_NAME=mentyx

# Frontend build-time: URL the browser uses to reach the backend.
# For local compose: http://localhost:8000
# For Cloud Run: set to the backend Cloud Run service URL at Terraform apply time.
VITE_API_URL=http://localhost:8000
