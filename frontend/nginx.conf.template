server {
    listen ${PORT};
    root /usr/share/nginx/html;
    index index.html;

    # SPA routing: serve index.html for any path not found on disk
    location / {
        try_files $uri $uri/ /index.html;
    }

    gzip on;
    gzip_types text/plain text/css application/javascript application/json image/svg+xml;
}
